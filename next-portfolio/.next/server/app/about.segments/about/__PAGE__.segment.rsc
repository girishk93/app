0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"container mx-auto px-6 lg:px-12 py-16 md:py-24 max-w-5xl","children":[["$","div",null,{"className":"mb-16","children":[["$","h1",null,{"className":"font-serif text-4xl md:text-5xl font-medium mb-4","children":"About Me"}],["$","div",null,{"className":"h-1 w-20 bg-accent rounded-full"}]]}],["$","div",null,{"className":"grid md:grid-cols-[1fr_350px] gap-12 lg:gap-24 items-start","children":[["$","div",null,{"className":"prose prose-invert prose-lg max-w-none text-muted-foreground","children":[["$","p",null,{"className":"text-2xl text-foreground font-medium mb-8 leading-snug","children":"Hey, I’m Girish. I’m a student, a creator, and someone who just really loves figuring out how to make businesses run smoother."}],["$","p",null,{"className":"mb-6 leading-relaxed","children":"Right now, I’m doing my Master's in Management at Toulouse Business School. But before coming to France, I was actually managing an operations team back in India. We handled the hiring workflows for over 15 different companies. That experience really opened my eyes to how much time businesses waste on chaotic, repetitive tasks—and how much happier clients are when you step in and fix those bottlenecks."}],["$","p",null,{"className":"mb-6 leading-relaxed","children":"Lately, I’ve been taking that operational mindset and applying it to the digital world. I help businesses upgrade their online presence by building custom websites and setting up automations, like WhatsApp AI chatbots using n8n. My goal is to take complex tech and make it simple, accessible, and actually useful for everyday business owners."}],["$","div",null,{"className":"my-10 p-6 border-l-2 border-accent bg-accent/5 rounded-r-xl","children":["$","p",null,{"className":"text-foreground font-medium text-lg italic mb-0","children":"\"I’m currently looking for a 6-12 month internship in operations or business automation. If you need help untangling a messy process, or just want to connect, feel free to reach out!\""}]}],["$","p",null,{"className":"mb-6 leading-relaxed","children":"Outside of all that, I'm usually studying International Financial Management, trying to learn French, or documenting my journey on my YouTube and Instagram channels. And if I'm not doing any of those, I'm probably at the gym."}]]}],["$","div",null,{"className":"relative sticky top-32","children":[["$","div",null,{"className":"relative aspect-[4/5] w-full rounded-2xl overflow-hidden border border-border shadow-2xl","children":[["$","$L2",null,{"src":"/profile-photo-new.jpg","alt":"Girish Kumar","fill":true,"className":"object-cover object-top","priority":true}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t from-background/40 to-transparent"}]]}],["$","div",null,{"className":"mt-8 grid grid-cols-2 gap-4","children":[["$","div",null,{"className":"p-4 rounded-xl border border-border/50 bg-card text-center","children":[["$","p",null,{"className":"text-2xl font-serif font-medium text-accent mb-1","children":"15+"}],["$","p",null,{"className":"text-xs text-muted-foreground uppercase tracking-wider","children":"Clients Handled"}]]}],["$","div",null,{"className":"p-4 rounded-xl border border-border/50 bg-card text-center","children":[["$","p",null,{"className":"text-2xl font-serif font-medium text-accent mb-1","children":"MSc"}],["$","p",null,{"className":"text-xs text-muted-foreground uppercase tracking-wider","children":"Management"}]]}]]}]]}]]}]]}],[["$","script","script-0",{"src":"/_next/static/chunks/0q2kz2_bfl2zf.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"gGCt3VX9dvtng5v65x7y5"}
